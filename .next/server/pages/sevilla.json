4609223246\">Lorival Gomes Martello</a>"],"photo_reference":"Aaw_FcJy3XFnLJc2l8Qc3YdZHdMek3xQVVZVZ052QuyW4r-5LcE2l_DXxwLMPPiTs6ZmWufvPuiX-UDPqrP-VLkYYtptxX3W59LQFFoXRjfmzU10q7FTp5-vyMqXv6KIma8QCtmGi63u18hZapLg3lFjXzsK5g78KA_FW767FqAAdoFmWkOK","width":3456}],"place_id":"ChIJMUirZEptEg0RFY0ufyUItyw","plus_code":{"compound_code":"92R2+HW Sevilla, España","global_code":"8C9P92R2+HW"},"rating":4.9,"reference":"ChIJMUirZEptEg0RFY0ufyUItyw","reviews":[{"author_name":"Lorival Gomes Martello","author_url":"https://www.google.com/maps/contrib/112080542964609223246/reviews","language":"es","original_language":"es","profile_photo_url":"https://lh3.googleusercontent.com/a-/AD_cMMT7ndXTrl_eBQXVG2TyhXEYgeFJe0m-ER9_u0HrRhmSCp8=s128-c0x00000000-cc-rp-mo-ba4","rating":5,"relative_time_description":"Hace 3 meses","text":"English Version below:\n\nCasa de cambio pequeña, pero bien ubicada y muy útil. Te ofrecen buenos tipos de cambio que pueden mejorar según el importe, como es de esperar, claro. La asistente que me atendió, Belén, fue muy servicial aunque yo no fui muy amable, porque tenía prisa por ir a trabajar. Se lo recomiendo a todo aquel que necesite este servicio, seguro que volveré siempre que lo necesite.\n\nSmall currency exchange office, but well located and very useful. They offer you good exchange rates that can improve according to the amount, as is to be expected, of course. The attendant who helped me, Belén, was very helpful even though I wasn't very friendly, because I was in a hurry to go to work. I recommend it to everyone who needs this service, I will surely come back whenever I need it.","time":1678982018,"translated":false},{"author_name":"marco perez","author_url":"https://www.google.com/maps/contrib/117358066258093699179/reviews","language":"es","original_language":"es","profile_photo_url":"https://lh3.googleusercontent.com/a/AAcHTtfGSfKsGD4tMAX1XUdiRS5HoKoX4YDlsh_-TC37jRPm=s128-c0x00000000-cc-rp-mo-ba2","rating":5,"relative_time_description":"Hace 1 mes","text":"Buena cotización y muy profesionales Nos atendieron Angela por telefono y Sara en la tienda. Te atienden con total confianza y mucha amabilidad y. Todo bien reflejado. Lo recomiendo sin dudas. A pesar de todo lo anterior me he decidido a quitarle una estrella.","time":1685540089,"translated":false},{"author_name":"Ibarra Pafundi","author_url":"https://www.google.com/maps/contrib/102746021394854331938/reviews","language":"es","original_language":"es","profile_photo_url":"https://lh3.googleusercontent.com/a-/AD_cMMSTHilHJWclJwZxt06VvFg0UJ2SO8QRDUy_rE9vi2ajzA=s128-c0x00000000-cc-rp-mo","rating":5,"relative_time_description":"en la última semana","text":"Sara gracias!!!Excelente operadora de cambio!! Y guia turistica","time":1687864293,"translated":false},{"author_name":"Guillermo Caviglia","author_url":"https://www.google.com/maps/contrib/115789555196768547093/reviews","language":"es","original_language":"es","profile_photo_url":"https://lh3.googleusercontent.com/a-/AD_cMMSdAC71ZDBY0pF0pc7wP6frnctbA-Jbh3-m911yPNAjpQ=s128-c0x00000000-cc-rp-mo","rating":5,"relative_time_description":"Hace 1 mes","text":"Excelente casa de cambio, por lo que vi la única que tiene cerrada la puerta de ingreso para mayor seguridad.\nLa atención de Sara es destacable, explicó todo con detalles y mucha paciencia, recorri varias casa antes de cambiar y sin lugar a dudas la mejor opción.","time":1685681367,"translated":false},{"author_name":"Lolo","author_url":"https://www.google.com/maps/contrib/107521446242727967921/reviews","language":"es","original_language":"es","profile_photo_url":"https://lh3.googleusercontent.com/a-/AD_cMMTMTSni6szfRTpCe4mIk3Pq0dXhsPm383TvfD98SeuI6A=s128-c0x00000000-cc-rp-mo","rating":5,"relative_time_description":"Hace 3 semanas","text":"Mi primera experiencia vendiendo oro, no tenía ni idea de cómo funciona este tipo de negocios ni sabía donde ir y también miedo a ser estafado. Hice una búsqueda en Google y encontré varios establecimientos, me decidí por este ya que me dió mucha confianza por la cantidad de comentarios positivos que tiene. Fue un gran acierto, me atendieron súper bien, te explican todo al detalle con amabilidad y simpatía.\nTengo más cosas para vender y con toda seguridad iré allí.\nMuchas gracias.","time":1686307168,"translated":false}],"types":["jewelry_store","finance","point_of_interest","store","establishment"],"url":"https://maps.google.com/?cid=3222053015547448597","user_ratings_total":673,"utc_offset":120,"vicinity":"Calle San Eloy, 43, Sevilla","website":"https://quickgold.es/compro-oro-sevilla/calle-san-eloy-43/?utm_source=gmb&utm_medium=boton&utm_content&utm_campaign=sitio-web-gmb","wheelchair_accessible_entrance":true},"status":"OK"}},"__N_SSG":true}